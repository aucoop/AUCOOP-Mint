#!/bin/bash
# AUCOOP Recovery - Custom Clonezilla restore script
# This script shows two confirmation prompts before restoring the AUCOOP image.

set -e

# Mount the image from the live media if not already available
if [ ! -d "/home/partimag/aucoop-mint22.3-2026-03" ]; then
  mkdir -p /home/partimag
  for mnt in /run/live/medium /lib/live/mount/medium /live/image /cdrom; do
    if [ -d "$mnt/home/partimag/aucoop-mint22.3-2026-03" ]; then
      mount --bind "$mnt/home/partimag" /home/partimag
      break
    fi
  done
fi

if [ ! -d "/home/partimag/aucoop-mint22.3-2026-03" ]; then
  echo "ERROR: Could not find the AUCOOP image on this media!"
  echo "Press Enter to reboot..."
  read
  reboot
fi

# Colors
RED='\033[1;31m'
GREEN='\033[1;32m'
YELLOW='\033[1;33m'
CYAN='\033[1;36m'
BOLD='\033[1m'
NC='\033[0m'

clear

echo ""
echo -e "${GREEN}=============================================${NC}"
echo -e "${GREEN}       AUCOOP - System Recovery Tool         ${NC}"
echo -e "${GREEN}=============================================${NC}"
echo ""
echo -e "${CYAN}This tool will install the AUCOOP Linux Mint${NC}"
echo -e "${CYAN}system on this computer.${NC}"
echo ""

# Detect the target disk (first internal disk)
TARGET_DISK=""
for disk in sda sdb nvme0n1 vda; do
  if [ -e /dev/$disk ]; then
    # Skip USB/removable devices
    removable=$(cat /sys/block/$disk/removable 2>/dev/null || echo "0")
    if [ "$removable" = "0" ]; then
      TARGET_DISK="$disk"
      break
    fi
  fi
done

if [ -z "$TARGET_DISK" ]; then
  echo -e "${RED}ERROR: No internal disk found!${NC}"
  echo "Please check that the computer has an internal hard drive."
  echo "Press Enter to reboot..."
  read
  reboot
fi

DISK_SIZE=$(lsblk -dno SIZE /dev/$TARGET_DISK 2>/dev/null || echo "unknown")
DISK_MODEL=$(lsblk -dno MODEL /dev/$TARGET_DISK 2>/dev/null || echo "unknown")

echo -e "  Target disk:  ${BOLD}/dev/$TARGET_DISK${NC}"
echo -e "  Size:         ${BOLD}$DISK_SIZE${NC}"
echo -e "  Model:        ${BOLD}$DISK_MODEL${NC}"
echo ""
echo -e "${YELLOW}---------------------------------------------${NC}"
echo ""

# First confirmation
echo -e "${BOLD}Do you want to install AUCOOP on this computer?${NC}"
echo -e "  Type ${GREEN}yes${NC} to continue, or ${RED}no${NC} to cancel."
echo ""
echo -n ">>> "
read answer1

if [ "$answer1" != "yes" ]; then
  echo ""
  echo "Installation cancelled. Rebooting..."
  sleep 3
  reboot
fi

echo ""
echo -e "${RED}=============================================${NC}"
echo -e "${RED}              !! WARNING !!                  ${NC}"
echo -e "${RED}=============================================${NC}"
echo ""
echo -e "${RED}This will ERASE ALL DATA on /dev/$TARGET_DISK${NC}"
echo -e "${RED}This action is NON-REVERSIBLE.${NC}"
echo -e "${RED}All existing files and operating systems on${NC}"
echo -e "${RED}this disk will be permanently destroyed.${NC}"
echo ""
echo -e "${BOLD}Are you sure you want to continue?${NC}"
echo -e "  Type ${GREEN}YES${NC} (uppercase) to confirm, anything else to cancel."
echo ""
echo -n ">>> "
read answer2

if [ "$answer2" != "YES" ]; then
  echo ""
  echo "Installation cancelled. Rebooting..."
  sleep 3
  reboot
fi

echo ""
echo -e "${GREEN}Starting AUCOOP installation...${NC}"
echo -e "${CYAN}This may take several minutes. Please do not${NC}"
echo -e "${CYAN}turn off the computer.${NC}"
echo ""

# Run the actual Clonezilla restore
ocs-sr -g auto -e1 auto -e2 -c -r -j2 -icds -k1 -batch -p reboot restoredisk aucoop-mint22.3-2026-03 "$TARGET_DISK"
